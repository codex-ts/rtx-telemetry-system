# Copy this file to `.env` and fill in your own values.

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx        # publishable / anon key (used by the daemon)
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx     # service-role secret key (used by ai_server.py, bypasses RLS)

# Google Gemini API key for the AI copilot
GEMINI_API_KEY=your-gemini-api-key

# Operator login the daemon uses to authenticate (a Supabase Auth user)
OPERATOR_EMAIL=you@example.com
OPERATOR_PASSWORD=your-password
